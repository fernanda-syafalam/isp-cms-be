# Copy to .env for local development. Real secrets must never be
# committed; production values come from the secret manager / k8s
# Secret. See src/config/env.schema.ts for the full validated list.
NODE_ENV=development
PORT=3000

# Local Postgres from docker-compose.yml
DATABASE_URL=postgres://app:app@localhost:5432/app
DATABASE_POOL_SIZE=10

# Redis — backs the throttler today, will back BullMQ + cache later
REDIS_URL=redis://localhost:6379

# Global rate limit. Defaults match v2 doc Pilar 2.
THROTTLER_TTL_MS=60000
THROTTLER_LIMIT=100

# JWT signing key. Use `openssl rand -hex 32` for production. The schema
# rejects values shorter than 32 characters.
JWT_SECRET=replace-with-32-or-more-random-characters
JWT_EXPIRES_IN=15m

# Refresh tokens are opaque (not JWTs), single-use, stored hashed in
# Redis. TTL in seconds — default is 7 days.
REFRESH_TOKEN_TTL_SECONDS=604800

# AES-256-GCM key encrypting the TOTP 2FA secret at rest (F2). Must
# base64-decode to exactly 32 bytes — generate with `openssl rand -base64 32`.
TWOFA_ENC_KEY=replace-with-output-of-openssl-rand-base64-32

# Pino log level: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info

# CORS — comma-separated list of browser SPA origins. No wildcard allowed
# when credentials:true. Add staging/prod FE domains here.
CORS_ORIGINS=http://localhost:5173

# httpOnly refresh_token cookie settings.
# COOKIE_SECURE should be true in production (requires HTTPS).
COOKIE_SECURE=false
# COOKIE_DOMAIN is optional; omit for same-site usage.
# COOKIE_DOMAIN=.example.com
COOKIE_SAMESITE=lax

# OpenTelemetry. Leave OTEL_EXPORTER_OTLP_ENDPOINT unset to disable
# the exporters (auto-instrumentation still loads, spans are dropped).
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_SERVICE_NAME=isp-cms-be
SERVICE_VERSION=0.0.0

# Network enforcement (P2.5). 'simulation' (default) only writes the DB flag;
# 'live' also pushes PPPoE enable/disable to the real RouterOS device.
ROUTEROS_MODE=simulation
# Required when ROUTEROS_MODE=live — the shared RouterOS API password.
# ROUTEROS_API_PASSWORD=

# WhatsApp delivery transport (ADR-0017). 'log' (default) only writes the
# notification_log row (dev/demo, no external call); 'wa' sends through a
# Fonnte/Wablas-class WhatsApp HTTP gateway.
NOTIFICATION_MODE=log
# Required when NOTIFICATION_MODE=wa — the gateway's send endpoint + token.
# WA_API_URL=https://api.fonnte.com/send
# WA_API_TOKEN=

# Payment gateway (ADR-0016). 'simulation' (default) keeps the existing
# dev/demo mock VA/QR flow, no real money moves. 'live' charges real
# invoices through Tripay and only settles via its signed webhook
# (POST /v1/webhooks/tripay) — see src/modules/invoices/payment-gateway/.
PAYMENT_MODE=simulation
# Required when PAYMENT_MODE=live — from the Tripay merchant dashboard.
# Use the sandbox base URL/credentials until verified against production.
# TRIPAY_API_KEY=
# TRIPAY_PRIVATE_KEY=
# TRIPAY_MERCHANT_CODE=
# TRIPAY_BASE_URL=https://tripay.co.id/api-sandbox

{
  "name": "boilerplate-nestjs",
  "version": "0.1.0",
  "description": "NestJS service boilerplate (Fastify + Vitest + Biome). See docs/Backend-Best-Practices-NestJS-v2.md and docs/adr/.",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "dev:worker": "nest start --watch --entryFile worker",
    "start": "node dist/main.js",
    "start:worker": "node dist/worker.js",
    "start:debug": "nest start --debug --watch",
    "lint": "biome check --write",
    "lint:ci": "biome check",
    "format": "biome format --write",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:e2e": "vitest run test/**/*.e2e-spec.ts",
    "test:int": "vitest run --config vitest.int.config.ts",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:check": "drizzle-kit check",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx --env-file-if-exists=.env src/infrastructure/database/seed.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@nest-lab/throttler-storage-redis": "^1.2.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-fastify": "^11.0.1",
    "@nestjs/throttler": "^6.5.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.75.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.217.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.217.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-metrics": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.217.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "argon2": "^0.44.0",
    "bullmq": "^5.76.6",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.0.0",
    "ioredis": "^5.10.1",
    "nestjs-pino": "^4.6.1",
    "nestjs-zod": "^5.3.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/core": "^1.7.0",
    "@testcontainers/postgresql": "^11.14.0",
    "@types/node": "^24.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^2.1.0",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.1.3",
    "source-map-support": "^0.5.21",
    "testcontainers": "^11.14.0",
    "ts-loader": "^9.5.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "unplugin-swc": "^1.5.1",
    "vitest": "^2.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "@nestjs/core",
      "@swc/core",
      "argon2",
      "cpu-features",
      "esbuild",
      "protobufjs",
      "ssh2",
      "unrs-resolver"
    ]
  }
}

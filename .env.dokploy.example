# Production environment for the Dokploy Compose deployment of isp-cms-be.
#
# Do NOT commit real secrets. In Dokploy, paste these into the
# service's "Environment" tab (Settings -> Environment). Compose reads
# them via ${VAR} interpolation in docker-compose.dokploy.yml.
#
# Generate the secrets fresh — never reuse the .env.example placeholders:
#   JWT_SECRET     : openssl rand -hex 32
#   TWOFA_ENC_KEY  : openssl rand -base64 32   (must decode to 32 bytes)

# --- Connection strings from the Dokploy MANAGED databases ---
# Copy the *internal* connection URLs shown on each managed DB's page.
# Host is the DB's internal service name on dokploy-network, not localhost.
DATABASE_URL=postgres://USER:PASSWORD@isp-cms-be-postgres-XXXX:5432/app
DATABASE_POOL_SIZE=10
REDIS_URL=redis://default:PASSWORD@isp-cms-be-redis-XXXX:6379

# --- Auth / crypto secrets (generate fresh, see above) ---
JWT_SECRET=replace-with-openssl-rand-hex-32
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_TTL_SECONDS=604800
TWOFA_ENC_KEY=replace-with-openssl-rand-base64-32

# --- CORS + cookie (subdomain topology) ---
# FE origin(s), comma-separated, no trailing slash, no wildcard.
CORS_ORIGINS=https://isp.astaweda.com
# Cross-site XHR from app.* to api.* requires SameSite=None + Secure.
COOKIE_SECURE=true
COOKIE_SAMESITE=none

# --- Ops ---
LOG_LEVEL=info
THROTTLER_TTL_MS=60000
THROTTLER_LIMIT=100
OTEL_SERVICE_NAME=isp-cms-be
SERVICE_VERSION=0.0.0

# Network enforcement: keep 'simulation' unless the real RouterOS is wired.
ROUTEROS_MODE=simulation
# ROUTEROS_API_PASSWORD=   # only when ROUTEROS_MODE=live
